<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".watchlist.ui.views.watchlistSearch.Watchlist_Fragment">

    <androidx.appcompat.widget.SearchView
        android:id="@+id/svWatchlistSearch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginVertical="15dp"
        android:layout_marginHorizontal="15dp"
        android:background="@drawable/searchbar_background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/btnChangeWatchlistSearch" />

    <ImageButton
        android:id="@+id/btnChangeWatchlistSearch"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_television"
        app:tint="@color/white"
        android:background="@drawable/btn_changemode_background"
        android:layout_marginVertical="15dp"
        android:layout_marginHorizontal="15dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        />

    <!--
    <Button
        android:id="@+id/btnChangeWatchlistSearch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_movie"
        app:tint="@color/white"
        android:layout_marginVertical="15dp"
        android:layout_marginHorizontal="15dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>
    -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvWatchlistSearch"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/svWatchlistSearch"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

    <ProgressBar
        android:id="@+id/pbWatchlistSearch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    <TextView
        android:id="@+id/tvWatchlistSearchInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:padding="10dp"
        tools:text ="KJLSDFLKJDLFSÑJDFSÑLKJDFSÑLKJLFDÑSKJDÑFLSKJÑLKFDSJLÑFKDSJÑLFSDJLÑSFDJFSD"
        android:textSize="18dp"
        android:textStyle="italic"/>

</androidx.constraintlayout.widget.ConstraintLayout>