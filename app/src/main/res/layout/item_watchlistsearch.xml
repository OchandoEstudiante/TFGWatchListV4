<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="230dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardBackgroundColor="@color/cardviewWatchlistBackgroundColor"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    android:layout_marginVertical="6dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/ivMediaBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:alpha="0.4"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <ImageView
            android:id="@+id/itemMediaImage"
            android:layout_width="140dp"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent">
        </ImageView>

        <TextView
            android:id="@+id/itemMediaName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Ejemplo"
            android:textColor="@color/white"
            android:textSize="20dp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintLeft_toRightOf="@id/itemMediaImage"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_margin="7dp"/>

        <TextView
            android:id="@+id/itemMediaDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Ejemplo"
            android:textColor="@color/white"
            android:textSize="16dp"
            android:textStyle="bold"
            android:layout_margin="7dp"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintLeft_toRightOf="@id/itemMediaImage"
            app:layout_constraintTop_toBottomOf="@id/itemMediaName"
            />

        <TextView
            android:id="@+id/itemMediaPreview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Ejemplo"
            android:textColor="@color/white"
            android:textSize="16dp"
            android:textStyle="italic"
            android:layout_margin="7dp"
            app:layout_constraintTop_toBottomOf="@id/itemMediaDate"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintLeft_toRightOf="@id/itemMediaImage"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>