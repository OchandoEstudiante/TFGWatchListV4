<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".watchlist.ui.views.watchlistEpisodes.WatchlistEpisodesFragment">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardViewTopBarEpisodes"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/ivSerieImageWatchlistTemporada"
                android:layout_width="110dp"
                android:layout_height="match_parent"
                app:layout_constraintLeft_toLeftOf="parent"
                android:scaleType="centerCrop"/>

            <TextView
                android:id="@+id/tvTituloTemporadaWatchlistTemporada"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ejemplo"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"
                android:layout_marginHorizontal="15dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintLeft_toRightOf="@id/ivSerieImageWatchlistTemporada"/>

            <ScrollView
                android:id="@+id/scrollWatchlistDetails"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintRight_toRightOf="parent"
                android:layout_marginHorizontal="15dp"
                android:layout_marginVertical="10dp"
                app:layout_constraintLeft_toRightOf="@id/ivSerieImageWatchlistTemporada"
                app:layout_constraintTop_toBottomOf="@id/tvTituloTemporadaWatchlistTemporada"
                app:layout_constraintBottom_toTopOf="@id/tvDateSeason">

                <TextView
                    android:id="@+id/tvPremisaTemporadaWatchlistTemporada"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ejemplo"
                    android:textSize="16dp"
                    android:scrollbars="vertical"
                    app:layout_constraintTop_toBottomOf="@id/tvTituloTemporadaWatchlistTemporada"
                    app:layout_constraintLeft_toRightOf="@id/ivSerieImageWatchlistTemporada"
                    app:layout_constraintRight_toRightOf="parent"/>

            </ScrollView>

            <TextView
                android:id="@+id/tvDateSeason"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                android:layout_marginVertical="10dp"
                app:layout_constraintTop_toBottomOf="@id/scrollWatchlistDetails"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toRightOf="@id/ivSerieImageWatchlistTemporada"
                app:layout_constraintRight_toRightOf="parent"
                android:textSize="16dp"
                android:textStyle="bold"
                tools:text="Proximamente"/>


        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <Spinner
        android:id="@+id/spSeasonsEpisodes"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/spinner_background"
        android:layout_marginHorizontal="20dp"
        android:layout_marginVertical="10dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardViewTopBarEpisodes"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvWatchlistEpisodes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/spSeasonsEpisodes"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <ProgressBar
        android:id="@+id/pbEpisodesWatchlist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>